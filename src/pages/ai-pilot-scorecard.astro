---
const questions = [
  {
    id: "business_value",
    title: "Clear business value",
    description:
      "Is there a specific business problem, metric, or workflow this AI initiative is expected to improve?",
  },
  {
    id: "unique_data",
    title: "Useful data advantage",
    description:
      "Does the product have access to data that meaningfully improves relevance, performance, or defensibility?",
  },
  {
    id: "workflow_fit",
    title: "Workflow fit",
    description:
      "Will this solution live inside a real user workflow instead of sitting beside it as a disconnected demo?",
  },
  {
    id: "evaluation",
    title: "Evaluation readiness",
    description:
      "Do you know how success will be measured in production, not just in a test or demo setting?",
  },
  {
    id: "adoption",
    title: "Adoption path",
    description:
      "Is there a realistic plan for onboarding, trust, change management, and internal buy-in?",
  },
  {
    id: "governance",
    title: "Governance and risk",
    description:
      "Have privacy, safety, compliance, and escalation paths been considered early enough?",
  },
  {
    id: "economics",
    title: "Economics at scale",
    description:
      "Can the solution remain useful and financially sensible as usage grows?",
  },
  {
    id: "ownership",
    title: "Clear ownership",
    description:
      "Is there a clear product owner who will make trade-offs, prioritize work, and drive execution?",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AI Pilot Scorecard | Matt Ghoreishi</title>
    <meta
      name="description"
      content="A practical interactive tool to assess whether an AI initiative is ready to move beyond demo mode."
    />
    <style>
      :root {
        --bg: #07111f;
        --panel: #101a2b;
        --panel2: #0d1624;
        --text: #eef3fb;
        --muted: #9ba9be;
        --accent: #2f6df6;
        --border: rgba(255, 255, 255, 0.08);
        --good: #8de0ae;
        --mid: #f0cf84;
        --bad: #f1a0a0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }

      .wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 48px 20px 80px;
      }

      .back {
        display: inline-block;
        margin-bottom: 24px;
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }

      h1 {
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1.05;
        margin: 0 0 12px;
      }

      .lead {
        color: var(--muted);
        max-width: 760px;
        font-size: 1.05rem;
        margin-bottom: 32px;
      }

      .panel {
        background: linear-gradient(180deg, var(--panel), var(--panel2));
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: 24px;
        margin-bottom: 20px;
      }

      .question {
        margin-bottom: 18px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--border);
      }

      .question:last-child {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: 0;
      }

      .question h3 {
        margin: 0 0 8px;
        font-size: 1.1rem;
      }

      .question p {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .options label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.02);
        cursor: pointer;
      }

      .actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      button {
        border: 0;
        border-radius: 999px;
        padding: 14px 18px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
      }

      .primary {
        background: var(--accent);
        color: white;
      }

      .secondary {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border);
      }

      .result {
        display: none;
      }

      .result.show {
        display: block;
      }

      .score {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 8px;
      }

      .badge {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .badge.good {
        background: rgba(31, 157, 85, 0.16);
        color: var(--good);
      }

      .badge.mid {
        background: rgba(217, 164, 65, 0.16);
        color: var(--mid);
      }

      .badge.bad {
        background: rgba(214, 69, 69, 0.16);
        color: var(--bad);
      }

      .notes {
        color: var(--muted);
        margin-top: 16px;
      }

      .footer-note {
        margin-top: 28px;
        color: var(--muted);
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href="/">← Back to home</a>

      <h1>AI Pilot Scorecard</h1>
      <p class="lead">
        A practical tool to assess whether an AI initiative is ready to move
        beyond demo mode. This is a simple decision aid for product teams.
      </p>

      <div class="panel">
        {
          questions.map((q) => (
            <div class="question">
              <h3>{q.title}</h3>
              <p>{q.description}</p>
              <div class="options">
                <label><input type="radio" name={q.id} value="0" /> 0</label>
                <label><input type="radio" name={q.id} value="1" /> 1</label>
                <label><input type="radio" name={q.id} value="2" /> 2</label>
                <label><input type="radio" name={q.id} value="3" /> 3</label>
                <label><input type="radio" name={q.id} value="4" /> 4</label>
              </div>
            </div>
          ))
        }

        <div class="actions">
          <button class="primary" id="calculateBtn">Calculate score</button>
          <button class="secondary" id="resetBtn" type="button">Reset</button>
        </div>
      </div>

      <div class="panel result" id="resultBox">
        <div class="score" id="scoreText">0 / 32</div>
        <div class="badge mid" id="statusBadge">Needs work</div>
        <p id="statusText"></p>
        <div class="notes" id="notesText"></div>
      </div>

      <p class="footer-note">
        Version one is intentionally simple. No login, no backend, and no stored
        user account data.
      </p>
    </div>

    <script lang="ts">
      type Assessment = {
        label: string;
        badgeClass: "good" | "mid" | "bad";
        text: string;
        notes: string;
      };

      type StoredAnswers = Record<string, string>;

      const questionIds: string[] = [
        "business_value",
        "unique_data",
        "workflow_fit",
        "evaluation",
        "adoption",
        "governance",
        "economics",
        "ownership",
      ];

      const STORAGE_KEY = "ai-pilot-scorecard-v1";

      const calculateBtn = document.getElementById("calculateBtn");
      const resetBtn = document.getElementById("resetBtn");
      const resultBox = document.getElementById("resultBox");
      const scoreText = document.getElementById("scoreText");
      const statusBadge = document.getElementById("statusBadge");
      const statusText = document.getElementById("statusText");
      const notesText = document.getElementById("notesText");

      function getCheckedInput(name: string): HTMLInputElement | null {
        return document.querySelector(
          `input[name="${name}"]:checked`,
        ) as HTMLInputElement | null;
      }

      function getSpecificInput(
        name: string,
        value: string,
      ): HTMLInputElement | null {
        return document.querySelector(
          `input[name="${name}"][value="${value}"]`,
        ) as HTMLInputElement | null;
      }

      function saveState(): void {
        const data: StoredAnswers = {};

        questionIds.forEach((id) => {
          const checked = getCheckedInput(id);
          data[id] = checked ? checked.value : "";
        });

        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      }

      function loadState(): void {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;

        const data = JSON.parse(raw) as StoredAnswers;

        questionIds.forEach((id) => {
          const savedValue = data[id];
          if (savedValue === undefined || savedValue === "") return;

          const input = getSpecificInput(id, savedValue);
          if (input) input.checked = true;
        });
      }

      function getScore(): { total: number; answered: number } {
        let total = 0;
        let answered = 0;

        questionIds.forEach((id) => {
          const checked = getCheckedInput(id);
          if (checked) {
            total += Number(checked.value);
            answered += 1;
          }
        });

        return { total, answered };
      }

      function getAssessment(score: number): Assessment {
        if (score >= 25) {
          return {
            label: "Strong foundation",
            badgeClass: "good",
            text: "This initiative has a strong chance of becoming a real product if execution remains disciplined.",
            notes:
              "Next, validate adoption behavior, production measurement, and economics at scale.",
          };
        }

        if (score >= 17) {
          return {
            label: "Needs work",
            badgeClass: "mid",
            text: "There is real potential here, but important product risks still need to be resolved before scaling.",
            notes:
              "Focus first on workflow fit, measurable value, and clear ownership. These often matter more than model polish.",
          };
        }

        return {
          label: "Demo risk",
          badgeClass: "bad",
          text: "This currently looks more like a promising demo than a production-ready AI product.",
          notes:
            "Strengthen the business case, workflow integration, and evaluation plan before investing heavily in scale.",
        };
      }

      document
        .querySelectorAll<HTMLInputElement>('input[type="radio"]')
        .forEach((input) => {
          input.addEventListener("change", saveState);
        });

      if (
        calculateBtn &&
        resetBtn &&
        resultBox &&
        scoreText &&
        statusBadge &&
        statusText &&
        notesText
      ) {
        calculateBtn.addEventListener("click", () => {
          const { total, answered } = getScore();

          if (answered < questionIds.length) {
            alert("Please answer all questions before calculating the score.");
            return;
          }

          const assessment = getAssessment(total);

          scoreText.textContent = `${total} / 32`;
          statusText.textContent = assessment.text;
          notesText.textContent = assessment.notes;
          statusBadge.textContent = assessment.label;
          statusBadge.className = `badge ${assessment.badgeClass}`;

          resultBox.classList.add("show");
          resultBox.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        resetBtn.addEventListener("click", () => {
          localStorage.removeItem(STORAGE_KEY);

          document
            .querySelectorAll<HTMLInputElement>('input[type="radio"]')
            .forEach((input) => {
              input.checked = false;
            });

          resultBox.classList.remove("show");
        });
      }

      loadState();
    </script>
  </body>
</html>
